[MASTER]
# Only show warnings with the listed confidence levels. Leave empty to show all. Valid levels: HIGH, INFERENCE, INFERENCE_FAILURE, UNDEFINED.
confidence=
disable=
    missing-docstring,
    too-many-arguments,
    too-many-locals,
    too-many-instance-attributes,
    protected-access,
    no-member,
    import-error,

jobs=1
limit-inference-results=100
persistent=yes
suggestion-mode=yes
unsafe-load-any-extension=no

[MESSAGES CONTROL]
disable=
    C0330,  # Bad whitespace
    C0326,  # Bad whitespace
    C0103,  # Invalid name
    R0913,  # Too many arguments
    R0914,  # Too many local variables
    W0212,  # Protected access
    R0801,  # Duplicate code
    W1203,  # Logging percent format
    missing-docstring,

[REPORTS]
output-format=text
reports=no
evaluation=10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10)

[REFACTOR]
max-nested-blocks=5

[LOGGING]
logging-format-style=new
logging-modules=logging

[FORMAT]
max-line-length=100
indent-string='    '
indent-after-paren=4

[SPELLING]
spelling-dict=en_US
spelling-ignore-words=
spelling-private-word-hint=no
spelling-store-unknown-words=no

[VARIABLES]
allow-global-unused-variables=yes
dummy-variables-rgx=_+$|(_[a-zA-Z0-9_]*[a-zA-Z0-9]+?$)|dummy|^ignored_|^unused_

[DESIGN]
max-args=5
max-attributes=7
max-bool-expr=5
max-branches=12
max-locals=15
max-parents=7
max-public-methods=20
max-returns=6
max-statements=50
min-public-methods=2

[CLASSES]
exclude-protected=_asdict,_fields,_make,_replace,__new__,__subclasses__
valid-classmethod-first-arg=cls
valid-metaclass-first-arg=cls

[IMPORTS]
allow-wildcard-with-all=no
analyse-fallback-blocks=no
deprecated-modules=optparse,tkinter.tix
